# Hermes runtime (generated inside container / local profile)
.hermes/cache/
.hermes/sessions/
.hermes/logs/
.hermes/.env

# Logs & runtime state
logs/*
!logs/.gitkeep
*.log
*.log.*

# Self-improving store (generated at runtime)
data/*.json
data/*.json.tmp
!data/.gitkeep

# RAG: user PDFs/Word/FAQ + local Chroma indexes (not for git)
data/rag/**
!data/rag/.gitkeep
!data/rag/chroma/.gitkeep

