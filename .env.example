# =============================================================================
# HR AI Agent — Environment Variables
# Copy this file to .env and fill in production values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=hr-ai-agent
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
TZ=UTC
PYTHONUNBUFFERED=1

# -----------------------------------------------------------------------------
# LLM Provider (set ONE primary path)
# Hermes supports OpenRouter, OpenAI, Anthropic, or any OpenAI-compatible API.
# -----------------------------------------------------------------------------
# Optional force: openrouter | openai | anthropic
# HR_PROVIDER=openai

# OpenRouter (recommended multi-provider gateway)
OPENROUTER_API_KEY=

# Direct OpenAI (api.openai.com)
# Required together with an OpenAI model name (not claude/*).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Direct Anthropic
ANTHROPIC_API_KEY=

# Model — MUST match the key you set:
#   OpenAI:     gpt-4o-mini  |  gpt-4o  |  gpt-4.1-mini
#   Anthropic:  claude-sonnet-4-6  (or provider-native id)
#   OpenRouter: anthropic/claude-sonnet-4.6  |  openai/gpt-4o-mini
HR_MODEL=gpt-4o-mini

# Hermes injects reasoning.effort by default; OpenAI gpt-4o* rejects it.
# Leave false unless you use o-series / OpenRouter reasoning models.
HR_REASONING_ENABLED=false
# HR_REASONING_EFFORT=medium

# Optional custom OpenAI-compatible base URL (e.g. local vLLM / LiteLLM)
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1

# Optional explicit API key override for AIAgent (falls back to provider env vars)
# HR_API_KEY=

# -----------------------------------------------------------------------------
# Hermes Framework
# -----------------------------------------------------------------------------
HERMES_HOME=/home/hermes/.hermes
HERMES_ENABLE_PROJECT_PLUGINS=true
# Disable desktop / GUI / TUI surfaces in production
HERMES_TUI=0
HERMES_SKIP_DESKTOP=1

# -----------------------------------------------------------------------------
# HR Agent behaviour
# -----------------------------------------------------------------------------
EMPLOYEES_JSON_PATH=/app/data/employees.json
SYSTEM_PROMPT_PATH=/app/prompts/system_prompt.md
HR_MAX_ITERATIONS=20
HR_QUIET_MODE=true
HR_SKIP_MEMORY=true
HR_SKIP_CONTEXT_FILES=true
# Comma-separated Hermes toolsets enabled for the HR agent
HR_ENABLED_TOOLSETS=hr
# Session history size per client (in-memory multi-turn)
HR_SESSION_HISTORY_LIMIT=20

# -----------------------------------------------------------------------------
# HTTP API
# -----------------------------------------------------------------------------
API_WORKERS=1
API_RELOAD=false
# Optional simple bearer token for /v1/chat (leave empty to disable auth)
API_BEARER_TOKEN=
# CORS origins (comma-separated; * only for non-production)
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_DIR=/app/logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Healthcheck
# -----------------------------------------------------------------------------
HEALTHCHECK_URL=http://127.0.0.1:8080/health
HEALTHCHECK_TIMEOUT_SECONDS=5

# -----------------------------------------------------------------------------
# Docker Compose (host-side convenience; optional)
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=hr-ai-agent
