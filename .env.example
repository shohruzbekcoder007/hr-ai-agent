# =============================================================================
# LangChain SQLAgent (Langflow-compatible)
# =============================================================================

APP_NAME=ai-agents
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FORMAT=json
TZ=UTC
PYTHONUNBUFFERED=1

# LLM — Langflow SQLAgent used OpenAI gpt-4.1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1

# PostgreSQL (readonly role recommended)
DATABASE_URL=postgresql://readonly_user:password@host:5432/tuzilma

# SQLAgent knobs (Langflow defaults)
SQL_AGENT_MAX_ITERATIONS=15
# Retries on OpenAI 429 / transient network errors
SQL_AGENT_MAX_RETRIES=3
SQL_AGENT_VERBOSE=true
SQL_AGENT_HANDLE_PARSING_ERRORS=true

# Prompt Template (Langflow Prompt node)
SYSTEM_PROMPT_PATH=prompts/sql_agent_system.md

# Variant 2 — Hermes host + sql_ask → LangGraph SQL
HERMES_SYSTEM_PROMPT_PATH=prompts/hermes_coordinator.md
HERMES_ENABLED_TOOLSETS=sql_bridge
HERMES_MAX_ITERATIONS=12
HERMES_SESSION_HISTORY_LIMIT=20
# false = keep multi-turn history in host agent
HERMES_SKIP_MEMORY=false
HERMES_QUIET_MODE=true
HERMES_SKIP_CONTEXT_FILES=true
# OpenAI gpt-4* / gpt-4.1: must be false (Hermes default reasoning.effort breaks)
HERMES_REASONING_ENABLED=false
# HERMES_REASONING_EFFORT=medium
HERMES_HOME=/home/appuser/.hermes

CORS_ORIGINS=*
API_WORKERS=1
API_RELOAD=false
# API_BEARER_TOKEN=

HEALTHCHECK_URL=http://127.0.0.1:8080/health
HEALTHCHECK_TIMEOUT_SECONDS=5
